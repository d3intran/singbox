<Page x:Class="SingBoxTrayApp.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="Transparent"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      TextOptions.TextFormattingMode="Display"
      TextOptions.TextRenderingMode="ClearType"
      RenderOptions.ClearTypeHint="Enabled">

    <DockPanel Margin="16,8,16,16">
        <!-- Settings Center Title -->
        <TextBlock DockPanel.Dock="Top" Text="设置中心" FontSize="18" FontWeight="Bold" 
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="8,0,8,16" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8,0">
                <!-- Subscription Configuration Card -->
                <Border Background="{DynamicResource CardSubtleBg}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="订阅管理" FontSize="14" FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,12" />
                        
                        <!-- Fixed subscription address preview -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="订阅源" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,12,0" />
                            <ui:TextBox Grid.Column="1" Text="https://sing.2005666.xyz" IsReadOnly="True" 
                                        BorderThickness="1" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                        Background="{DynamicResource ControlAltFillColorTertiaryBrush}" />
                        </Grid>

                        <!-- Action Row: Last Sync Time on Left, Pull Button on Right -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="上次同步：" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="TxtLastSyncTime" Text="从未同步" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </StackPanel>
                            <ui:Button x:Name="BtnPull" Grid.Column="1" Content="同步云端配置" Appearance="Primary"
                                       Click="BtnPull_Click" Width="140" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Professional Console Log Card -->
                <Border Background="{DynamicResource CardSubtleBg}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <!-- Header with Log title and Utility buttons -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Text="运行监控日志" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button x:Name="BtnCopy" Content="复制" Appearance="Secondary"
                                           Click="BtnCopy_Click" Margin="0,0,6,0" Padding="8,4" FontSize="11" />
                                <ui:Button x:Name="BtnClear" Content="清空" Appearance="Secondary"
                                           Click="BtnClear_Click" Padding="8,4" FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <!-- Sleek Dark Mode Terminal Box -->
                        <Border Background="#0F0F12" BorderThickness="1" BorderBrush="#2A2A30" CornerRadius="6" Padding="10">
                            <TextBox x:Name="TxtLog" IsReadOnly="True" Height="220"
                                     VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                     FontFamily="Consolas" FontSize="12" Foreground="#85E89D"
                                     Background="Transparent" BorderThickness="0" CaretBrush="#85E89D" />
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
