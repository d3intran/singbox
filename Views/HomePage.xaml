<Page x:Class="SingBoxTrayApp.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="Transparent">

    <Page.Resources>
        <!-- Reusable iOS / Apple Style sliding ToggleButton template (2x size: 144x76 with premium depth) -->
        <Style x:Key="AppleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="144" />
            <Setter Property="Height" Value="76" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <!-- Ambient Glow/Shadow of the switch -->
                            <Border x:Name="GlowTrack" CornerRadius="38">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="TrackShadow" BlurRadius="12" Color="#4A6A9E" ShadowDepth="1" Opacity="0.12" />
                                </Border.Effect>
                            </Border>

                            <!-- Background Track (with luxurious gradient) -->
                            <Border x:Name="Track" CornerRadius="38" BorderThickness="1.5">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#2C2C2E" Offset="0.0" />
                                        <GradientStop Color="#3A3A3C" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#48484A" Offset="0.0" />
                                        <GradientStop Color="#2C2C2E" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                            </Border>
                            
                            <!-- Sliding White Thumb (with gorgeous 3D gradient and inner border) -->
                            <Border x:Name="Thumb" Width="68" Height="68" CornerRadius="34" HorizontalAlignment="Left" Margin="4,0,0,0"
                                    BorderBrush="#E5E5EA" BorderThickness="0.5">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFFFFF" Offset="0.0" />
                                        <GradientStop Color="#F2F4F7" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" Color="#000000" ShadowDepth="3" Opacity="0.28" />
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate" X="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <!-- Checked state: Apple Neon Green Glow and thumb slide -->
                            <Trigger Property="IsChecked" Value="True">
                                <!-- Change Track Background to premium iOS Green gradient -->
                                <Setter TargetName="Track" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#34D15E" Offset="0.0" />
                                            <GradientStop Color="#28B850" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Track" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4CE677" Offset="0.0" />
                                            <GradientStop Color="#24A346" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" 
                                                             Storyboard.TargetProperty="X" 
                                                             To="68" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" 
                                                             Storyboard.TargetProperty="X" 
                                                             To="0" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer Height="{Binding Path=ActualHeight, RelativeSource={RelativeSource AncestorType={x:Type Frame}}, FallbackValue=600}" VerticalScrollBarVisibility="Auto" Padding="16,12,16,16" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
        <StackPanel Margin="8,0">
            <!-- Apple-Style Dynamic Status & Switch Panel -->
            <Border Background="{DynamicResource CardSubtleBg}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Color="#4A6A9E" ShadowDepth="1" Opacity="0.08" />
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <!-- Status Title (Changed from "系统未连接" to "未连接") -->
                    <TextBlock x:Name="TxtStatusTitle" Text="未连接" FontSize="20" FontWeight="Bold" 
                               HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,8,0,16" />
                    
                    <!-- Large Apple Toggle Switch Control (Double size) -->
                    <ToggleButton x:Name="BtnAppleToggle" Style="{StaticResource AppleSwitchStyle}"
                                  Click="BtnAppleToggle_Click" HorizontalAlignment="Center" Margin="0,0,0,8" />
                </StackPanel>
            </Border>

            <!-- Performance / Core Metrics Grid (2 Columns) -->
            <UniformGrid Columns="2" Margin="0,0,0,16">
                <!-- Latency Metric -->
                <Border Background="{DynamicResource CardSubtleBg}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="4">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Color="#4A6A9E" ShadowDepth="0.5" Opacity="0.05" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="连接延迟" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TxtLatency" Text="-- ms" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Core Memory Metric -->
                <Border Background="{DynamicResource CardSubtleBg}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="4">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Color="#4A6A9E" ShadowDepth="0.5" Opacity="0.05" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="内核内存占用" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TxtMemory" Text="0.0 MB" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Active Node Metric -->
                <Border Background="{DynamicResource CardSubtleBg}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="4">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Color="#4A6A9E" ShadowDepth="0.5" Opacity="0.05" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="当前节点" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TxtActiveNode" Text="未连接" FontSize="14" FontWeight="SemiBold" 
                                   TextTrimming="CharacterEllipsis" Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Node Count Metric -->
                <Border Background="{DynamicResource CardSubtleBg}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="4">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Color="#4A6A9E" ShadowDepth="0.5" Opacity="0.05" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="已装载节点" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TxtNodeCount" Text="0 个" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Modern Scrollable Nodes List (Integrated Directly on Home Page) -->
            <Border Background="{DynamicResource CardSubtleBg}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Color="#4A6A9E" ShadowDepth="1" Opacity="0.08" />
                </Border.Effect>
                <DockPanel>
                    <!-- Search & Speed Test Header -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Sleek Search input -->
                        <ui:TextBox x:Name="TxtSearch" PlaceholderText="🔍 搜索节点名称..." 
                                    TextChanged="TxtSearch_TextChanged" Grid.Column="0" Margin="0,0,8,0"
                                    ClearButtonEnabled="True" VerticalAlignment="Center" />

                        <!-- Speed test action -->
                        <ui:Button x:Name="BtnTest" Content="一键测速" Appearance="Primary" Icon="{ui:SymbolIcon Flash20}"
                                   Grid.Column="1" Click="BtnTest_Click" Height="36" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Nodes list inside the scrollable panel (using ItemsControl directly) -->
                    <ItemsControl x:Name="NodesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Node Card Container with custom hover styling -->
                                <Border Background="{DynamicResource ControlAltFillColorQuaternaryBrush}"
                                        BorderBrush="{Binding CardBorderBrush}"
                                        BorderThickness="{Binding CardBorderThickness}"
                                        CornerRadius="6" Padding="12,10" Margin="0,0,0,6" Cursor="Hand"
                                        MouseLeftButtonUp="NodeCard_Click">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4" Color="#000000" ShadowDepth="0" Opacity="{Binding ShadowOpacity}" />
                                    </Border.Effect>
                                    
                                    <DockPanel>
                                        <!-- Latency Pill Indicator on the right -->
                                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                            <Border Background="{Binding PillBackground}" CornerRadius="10" Padding="8,3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DelayText}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding PillForeground}" />
                                            </Border>
                                        </StackPanel>

                                        <!-- Active checkmark indicator on the left -->
                                        <ui:SymbolIcon Symbol="CheckmarkCircle24" Filled="True" FontSize="18" 
                                                       DockPanel.Dock="Left" Margin="0,0,8,0" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SystemAccentColorBrush}"
                                                       Visibility="{Binding ActiveIconVisibility}" />
                                        
                                        <!-- Node Name -->
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" 
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" 
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
