<Page x:Class="SingBoxTrayApp.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="Transparent"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      TextOptions.TextFormattingMode="Display"
      TextOptions.TextRenderingMode="ClearType"
      RenderOptions.ClearTypeHint="Enabled">

    <Page.Resources>
        <!-- Premium 3D Layered iOS-Style Sliding Switch Style (Width/Height: 96x48) -->
        <Style x:Key="iOS3DSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="96" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid x:Name="SwitchRoot" Background="Transparent">
                            <!-- LAYER 1: Ambient Track Shadow -->
                            <Border x:Name="GlowTrack" CornerRadius="24" SnapsToDevicePixels="True" UseLayoutRounding="True">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="TrackShadow" BlurRadius="10" Color="#4A6A9E" ShadowDepth="1" Opacity="0.06" />
                                </Border.Effect>
                            </Border>

                            <!-- LAYER 2: Indented Track (Pill groove with inner shading) -->
                            <Border x:Name="Track" CornerRadius="24" BorderThickness="1" SnapsToDevicePixels="True" UseLayoutRounding="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#15171A" Offset="0.0" />
                                        <GradientStop Color="#222429" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#101114" Offset="0.0" />
                                        <GradientStop Color="#2E313A" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                
                                <Grid>
                                    <!-- Inner recessed shade to give 3D depth to the track -->
                                    <Border CornerRadius="23" BorderThickness="1" Opacity="0.15">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#000000" Offset="0.0" />
                                                <GradientStop Color="#FFFFFF" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                    </Border>
                                    <!-- Clean switch track without text to match pure iOS design -->
                                </Grid>
                            </Border>

                            <!-- LAYER 3: The 3D Floating Sliding Thumb (Slider handle) -->
                            <!-- Width/Height is 40x40, with Margin="4" centered inside 48px height track -->
                            <Border x:Name="Thumb" Width="40" Height="40" CornerRadius="20" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0,0,0"
                                    BorderThickness="1" SnapsToDevicePixels="True" UseLayoutRounding="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFFFFF" Offset="0.0" />
                                        <GradientStop Color="#F3F5F9" Offset="0.5" />
                                        <GradientStop Color="#DFE3EB" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFFFFF" Offset="0.0" />
                                        <GradientStop Color="#C2C9D6" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.Effect>
                                    <DropShadowEffect x:Name="ThumbShadow" BlurRadius="6" Color="#000000" ShadowDepth="2" Opacity="0.18" />
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate" X="0" />
                                </Border.RenderTransform>
                                
                                <!-- Sleek concentric inner ring for high-end mechanical feel -->
                                <Border CornerRadius="17" Margin="2" BorderThickness="1" BorderBrush="#EAF0F6" Background="Transparent" SnapsToDevicePixels="True" UseLayoutRounding="True" />
                            </Border>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <!-- Hover state: Thumb shadow intensifies slightly -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbShadow" Storyboard.TargetProperty="Opacity" To="0.26" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="ThumbShadow" Storyboard.TargetProperty="BlurRadius" To="9" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbShadow" Storyboard.TargetProperty="Opacity" To="0.18" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="ThumbShadow" Storyboard.TargetProperty="BlurRadius" To="6" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!-- Pressed state: Thumb depresses slightly -->
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbShadow" Storyboard.TargetProperty="ShadowDepth" To="1" Duration="0:0:0.05" />
                                            <DoubleAnimation Storyboard.TargetName="ThumbShadow" Storyboard.TargetProperty="BlurRadius" To="3" Duration="0:0:0.05" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbShadow" Storyboard.TargetProperty="ShadowDepth" To="2" Duration="0:0:0.05" />
                                            <DoubleAnimation Storyboard.TargetName="ThumbShadow" Storyboard.TargetProperty="BlurRadius" To="6" Duration="0:0:0.05" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!-- Checked (ON) State: Slide right and change background to rich iOS green -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#34D15E" Offset="0.0" />
                                            <GradientStop Color="#24B54C" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Track" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4CE677" Offset="0.0" />
                                            <GradientStop Color="#1E9B3E" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Smooth sliding animation with premium CubicEase out physics to X="48" -->
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" 
                                                             Storyboard.TargetProperty="X" 
                                                             To="48" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            
                                            <!-- Soft green ambient glow on track -->
                                            <DoubleAnimation Storyboard.TargetName="TrackShadow" Storyboard.TargetProperty="Opacity" To="0.18" Duration="0:0:0.2" />
                                            <ColorAnimation Storyboard.TargetName="TrackShadow" Storyboard.TargetProperty="Color" To="#34D15E" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Slide back to left (X="0") -->
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" 
                                                             Storyboard.TargetProperty="X" 
                                                             To="0" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            
                                            <!-- Restore track shadow -->
                                            <DoubleAnimation Storyboard.TargetName="TrackShadow" Storyboard.TargetProperty="Opacity" To="0.06" Duration="0:0:0.2" />
                                            <ColorAnimation Storyboard.TargetName="TrackShadow" Storyboard.TargetProperty="Color" To="#4A6A9E" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- High-End Dashboard Metric Card Style with 3D Hover elevation -->
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardSubtleBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="0" Y="0" />
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect x:Name="CardShadow" BlurRadius="8" Color="#4A6A9E" ShadowDepth="1" Opacity="0.06" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <!-- Smoothly translate upward by 4px -->
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="-4" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <!-- Increase shadow intensity -->
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                 To="0.18" Duration="0:0:0.2" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                 To="14" Duration="0:0:0.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <!-- Smoothly restore original position -->
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="0" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <!-- Restore shadow -->
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                 To="0.06" Duration="0:0:0.2" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                 To="8" Duration="0:0:0.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <ScrollViewer Height="{Binding Path=ActualHeight, RelativeSource={RelativeSource AncestorType={x:Type Frame}}, FallbackValue=600}" VerticalScrollBarVisibility="Auto" Padding="16,12,16,16" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
        <StackPanel Margin="8,0">
            <!-- Premium Dynamic Status & 3D Connection Panel -->
            <Border Background="{DynamicResource CardSubtleBg}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Color="#4A6A9E" ShadowDepth="1" Opacity="0.08" />
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <!-- Status Title -->
                    <TextBlock x:Name="TxtStatusTitle" Text="未连接" FontSize="20" FontWeight="Bold" 
                               HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,8,0,16" />
                    
                    <!-- Futuristic 3D iOS-Style Connection Switch -->
                    <ToggleButton x:Name="BtnAppleToggle" Style="{StaticResource iOS3DSwitchStyle}"
                                  Click="BtnAppleToggle_Click" HorizontalAlignment="Center" Margin="0,4,0,12" />
                </StackPanel>
            </Border>

            <!-- Performance / Core Metrics Grid (2 Columns) -->
            <UniformGrid Columns="2" Margin="0,0,0,16">
                <!-- Latency Metric -->
                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="连接延迟" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TxtLatency" Text="-- ms" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Core Memory Metric -->
                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="内核内存占用" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TxtMemory" Text="0.0 MB" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Active Node Metric -->
                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="当前节点" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TxtActiveNode" Text="未连接" FontSize="14" FontWeight="SemiBold" 
                                   TextTrimming="CharacterEllipsis" Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Node Count Metric -->
                <Border Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock Text="已装载节点" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TxtNodeCount" Text="0 个" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Modern Scrollable Nodes List (Integrated Directly on Home Page) -->
            <Border Background="{DynamicResource CardSubtleBg}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Color="#4A6A9E" ShadowDepth="1" Opacity="0.08" />
                </Border.Effect>
                <DockPanel>
                    <!-- Search & Speed Test Header -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Sleek Search input -->
                        <ui:TextBox x:Name="TxtSearch" PlaceholderText="🔍 搜索节点名称..." 
                                    TextChanged="TxtSearch_TextChanged" Grid.Column="0" Margin="0,0,8,0"
                                    ClearButtonEnabled="True" VerticalAlignment="Center" />

                        <!-- Speed test action -->
                        <ui:Button x:Name="BtnTest" Content="一键测速" Appearance="Primary" Icon="{ui:SymbolIcon Flash20}"
                                   Grid.Column="1" Click="BtnTest_Click" Height="36" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Nodes list inside the scrollable panel (using ItemsControl directly) -->
                    <ItemsControl x:Name="NodesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Node Card Container with custom hover styling -->
                                <Border Background="{DynamicResource ControlAltFillColorQuaternaryBrush}"
                                        BorderBrush="{Binding CardBorderBrush}"
                                        BorderThickness="{Binding CardBorderThickness}"
                                        CornerRadius="6" Padding="12,10" Margin="0,0,0,6" Cursor="Hand"
                                        MouseLeftButtonUp="NodeCard_Click">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4" Color="#000000" ShadowDepth="0" Opacity="{Binding ShadowOpacity}" />
                                    </Border.Effect>
                                    
                                    <DockPanel>
                                        <!-- Latency Pill Indicator on the right -->
                                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                            <Border Background="{Binding PillBackground}" CornerRadius="10" Padding="8,3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DelayText}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding PillForeground}" />
                                            </Border>
                                        </StackPanel>

                                        <!-- Active checkmark indicator on the left -->
                                        <ui:SymbolIcon Symbol="CheckmarkCircle24" Filled="True" FontSize="18" 
                                                       DockPanel.Dock="Left" Margin="0,0,8,0" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SystemAccentColorBrush}"
                                                       Visibility="{Binding ActiveIconVisibility}" />
                                        
                                        <!-- Node Name -->
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" 
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" 
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
