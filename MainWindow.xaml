<ui:FluentWindow x:Class="SingBoxTrayApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:SingBoxTrayApp"
        xmlns:views="clr-namespace:SingBoxTrayApp.Views"
        Title="singbox" Height="680" Width="430"
        Icon="pack://application:,,,/icon.png"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="Manual"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource WindowSubtleBlueBg}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        FontFamily="Microsoft YaHei, Segoe UI, Arial">

    <ui:FluentWindow.Resources>
        <Style x:Key="LargeTitleBarStyle" TargetType="{x:Type ui:TitleBar}" BasedOn="{StaticResource {x:Type ui:TitleBar}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ui:TitleBar}">
                        <Grid x:Name="PART_MainGrid"
                              HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid x:Name="TitleGrid"
                                  Grid.Column="0"
                                  Margin="{TemplateBinding Padding}"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="PART_Icon"
                                                  Grid.Column="0"
                                                  Width="32"
                                                  Height="32"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  AutomationProperties.AutomationId="TitleBarIcon"
                                                  Content="{TemplateBinding Icon}"
                                                  Focusable="False"
                                                  RenderOptions.BitmapScalingMode="HighQuality" />
                            </Grid>

                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding Header}" />

                                <Grid Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ui:TitleBarButton x:Name="PART_HelpButton"
                                                       Grid.Column="0"
                                                       AutomationProperties.AutomationId="TitleBarHelpButton"
                                                       ButtonType="Help" />

                                    <ui:TitleBarButton x:Name="PART_MinimizeButton"
                                                       Grid.Column="1"
                                                       AutomationProperties.AutomationId="TitleBarMinimizeButton"
                                                       ButtonType="Minimize" />

                                    <ui:TitleBarButton x:Name="PART_MaximizeButton"
                                                       Grid.Column="2"
                                                       AutomationProperties.AutomationId="TitleBarMaximizeButton"
                                                       ButtonType="Maximize"
                                                       IsHitTestVisible="True" />

                                    <ui:TitleBarButton x:Name="PART_CloseButton"
                                                       Grid.Column="4"
                                                       AutomationProperties.AutomationId="TitleBarCloseButton"
                                                       ButtonType="Close"
                                                       MouseOverBackground="{DynamicResource PaletteRedBrush}"
                                                       MouseOverButtonsForeground="White" />
                                </Grid>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Icon" Value="{x:Null}" />
                                    <Condition Property="Title" Value="{x:Null}" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TitleGrid" Property="Visibility" Value="Collapsed" />
                            </MultiTrigger>

                            <Trigger Property="ApplicationTheme" Value="Dark">
                                <Setter Property="ButtonsBackground">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#17FFFFFF" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <Trigger Property="Icon" Value="{x:Null}">
                                <Setter TargetName="PART_Icon" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="PART_Icon" Property="Margin" Value="0" />
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="ShowMaximize" Value="True" />
                                    <Condition Property="IsMaximized" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="PART_MaximizeButton" Property="ButtonType" Value="Restore" />
                            </MultiTrigger>

                            <Trigger Property="ShowHelp" Value="False">
                                <Setter TargetName="PART_HelpButton" Property="Visibility" Value="Collapsed" />
                            </Trigger>

                            <Trigger Property="ShowMinimize" Value="False">
                                <Setter TargetName="PART_MinimizeButton" Property="Visibility" Value="Collapsed" />
                            </Trigger>

                            <Trigger Property="ShowMaximize" Value="False">
                                <Setter TargetName="PART_MaximizeButton" Property="Visibility" Value="Collapsed" />
                            </Trigger>

                            <Trigger Property="ShowClose" Value="False">
                                <Setter TargetName="PART_CloseButton" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <DockPanel>
        <!-- Modern custom title bar with seamless integration and top-left icon (CanMaximize=False hides Maximize button) -->
        <ui:TitleBar x:Name="AppTitleBar" DockPanel.Dock="Top" Height="48" Padding="0,0" CanMaximize="False"
                 FontSize="18" FontWeight="Normal" Style="{StaticResource LargeTitleBarStyle}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Width="32" Height="32" Source="pack://application:,,,/icon.png" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <TextBlock Text="singbox"
                           VerticalAlignment="Center"
                           Margin="0,0,0,0"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           FontFamily="Microsoft YaHei, Segoe UI, Arial" />
            </ui:TitleBar.Header>
        </ui:TitleBar>
        
        <Grid>
            <!-- Sleek navigation layout style matching Microsoft PC Manager (slim left sidebar, buttons closer together) -->
            <ui:NavigationView x:Name="RootNavigation"
                               PaneDisplayMode="Left"
                               IsPaneToggleVisible="False"
                               IsPaneOpen="False"
                               IsBackButtonVisible="Collapsed"
                               CompactPaneLength="83"
                               Background="Transparent">
                <ui:NavigationView.Resources>
                    <Style TargetType="{x:Type ui:NavigationViewItem}">
                        <Setter Property="Height" Value="52" />
                        <Setter Property="Margin" Value="0,2" />
                    </Style>
                </ui:NavigationView.Resources>
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Content="首页" TargetPageType="{x:Type views:HomePage}">
                        <ui:NavigationViewItem.Icon>
                            <!-- Type-safe high-end colored gradient Home vector icon -->
                            <ui:ImageIcon Width="26" Height="26">
                                <ui:ImageIcon.Source>
                                    <DrawingImage>
                                        <DrawingImage.Drawing>
                                            <DrawingGroup>
                                                <!-- Base body: Soft ice blue -->
                                                <GeometryDrawing Brush="#EBF4FF">
                                                    <GeometryDrawing.Geometry>
                                                        <PathGeometry Figures="M3,10.5 L12,2.5 L21,10.5 V20 A1.5,1.5 0 0 1 19.5,21.5 H4.5 A1.5,1.5 0 0 1 3,20 Z" />
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                                <!-- Body overlay gradient -->
                                                <GeometryDrawing>
                                                    <GeometryDrawing.Brush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#250072FF" Offset="0.0"/>
                                                            <GradientStop Color="#6000C6FF" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </GeometryDrawing.Brush>
                                                    <GeometryDrawing.Geometry>
                                                        <PathGeometry Figures="M3,10.5 L12,2.5 L21,10.5 V20 A1.5,1.5 0 0 1 19.5,21.5 H4.5 A1.5,1.5 0 0 1 3,20 Z" />
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                                <!-- Roof gradient -->
                                                <GeometryDrawing>
                                                    <GeometryDrawing.Brush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#00C6FF" Offset="0.0"/>
                                                            <GradientStop Color="#0072FF" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </GeometryDrawing.Brush>
                                                    <GeometryDrawing.Geometry>
                                                        <PathGeometry Figures="M1.5,11 L12,1.8 L22.5,11 H19.5 L12,4.3 L4.5,11 Z" />
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                                <!-- Door warm sunset gradient -->
                                                <GeometryDrawing>
                                                    <GeometryDrawing.Brush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#FFB199" Offset="0.0"/>
                                                            <GradientStop Color="#FF0844" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </GeometryDrawing.Brush>
                                                    <GeometryDrawing.Geometry>
                                                        <PathGeometry Figures="M10,15 H14 V21.5 H10 Z" />
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                            </DrawingGroup>
                                        </DrawingImage.Drawing>
                                    </DrawingImage>
                                </ui:ImageIcon.Source>
                            </ui:ImageIcon>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                    <ui:NavigationViewItem Content="设置" TargetPageType="{x:Type views:SettingsPage}">
                        <ui:NavigationViewItem.Icon>
                            <!-- Type-safe high-end colored gradient Settings gear vector icon -->
                            <ui:ImageIcon Width="26" Height="26">
                                <ui:ImageIcon.Source>
                                    <DrawingImage>
                                        <DrawingImage.Drawing>
                                            <DrawingGroup>
                                                <!-- Gear ring outline with premium titanium/slate-gray gradient -->
                                                <GeometryDrawing>
                                                    <GeometryDrawing.Brush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#4A5568" Offset="0.0"/>
                                                            <GradientStop Color="#718096" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </GeometryDrawing.Brush>
                                                    <GeometryDrawing.Geometry>
                                                        <PathGeometry Figures="M19.4,15a1.65,1.65 0 0 0 .33,1.82l.06,.06a2,2 0 1 1-2.83,2.83l-.06-.06a1.65,1.65 0 0 0-1.82-.33 1.65,1.65 0 0 0-1,1.51V21a2,2 0 0 1-4,0v-.09A1.65,1.65 0 0 0 9,19.4a1.65,1.65 0 0 0-1.82,.33l-.06,.06a2,2 0 1 1-2.83-2.83l.06-.06a1.65,1.65 0 0 0 .33-1.82 1.65,1.65 0 0 0-1.51-1H3a2,2 0 0 1 0-4h.09A1.65,1.65 0 0 0 4.6,9a1.65,1.65 0 0 0-.33-1.82l-.06-.06a2,2 0 1 1 2.83-2.83l.06.06a1.65,1.65 0 0 0 1.82.33H9a1.65,1.65 0 0 0 1-1.51V3a2,2 0 0 1 4 0v.09a1.65,1.65 0 0 0 1,1.51 1.65,1.65 0 0 0 1.82-.33l.06-.06a2,2 0 1 1 2.83 2.83l-.06.06a1.65,1.65 0 0 0-.33 1.82V9a1.65,1.65 0 0 0 1.51,1H21a2,2 0 0 1 0,4h-.09a1.65,1.65 0 0 0-1.51,1z" />
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                                <!-- Inner core: Brushed aluminum / silver gradient -->
                                                <GeometryDrawing>
                                                    <GeometryDrawing.Brush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#CBD5E1" Offset="0.0"/>
                                                            <GradientStop Color="#F8FAFC" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </GeometryDrawing.Brush>
                                                    <GeometryDrawing.Geometry>
                                                        <EllipseGeometry Center="12,12" RadiusX="3.5" RadiusY="3.5" />
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                            </DrawingGroup>
                                        </DrawingImage.Drawing>
                                    </DrawingImage>
                                </ui:ImageIcon.Source>
                            </ui:ImageIcon>
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                </ui:NavigationView.MenuItems>
            </ui:NavigationView>
        </Grid>
    </DockPanel>
</ui:FluentWindow>
